<Application x:Class="TranslationHelper.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>

        <!-- App icon: globe symbolizing multilingualism -->
        <DrawingImage x:Key="AppIcon">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <!-- Globe fill -->
                    <GeometryDrawing Brush="#1976D2"
                                     Geometry="M16,3 A13,13 0 1 1 15.999,3 Z"/>
                    <!-- Central meridian (narrow ellipse) -->
                    <GeometryDrawing Brush="Transparent"
                                     Geometry="M16,3 C19.5,3 21,9 21,16 C21,23 19.5,29 16,29 C12.5,29 11,23 11,16 C11,9 12.5,3 16,3 Z">
                        <GeometryDrawing.Pen><Pen Brush="White" Thickness="1.1"/></GeometryDrawing.Pen>
                    </GeometryDrawing>
                    <!-- Equator -->
                    <GeometryDrawing Geometry="M3,16 L29,16">
                        <GeometryDrawing.Pen><Pen Brush="White" Thickness="1.1"/></GeometryDrawing.Pen>
                    </GeometryDrawing>
                    <!-- Upper parallel -->
                    <GeometryDrawing Geometry="M5,10 L27,10">
                        <GeometryDrawing.Pen><Pen Brush="White" Thickness="0.9"/></GeometryDrawing.Pen>
                    </GeometryDrawing>
                    <!-- Lower parallel -->
                    <GeometryDrawing Geometry="M5,22 L27,22">
                        <GeometryDrawing.Pen><Pen Brush="White" Thickness="0.9"/></GeometryDrawing.Pen>
                    </GeometryDrawing>
                    <!-- Globe outline -->
                    <GeometryDrawing Brush="Transparent"
                                     Geometry="M16,3 A13,13 0 1 1 15.999,3 Z">
                        <GeometryDrawing.Pen><Pen Brush="#0D47A1" Thickness="1.5"/></GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <Style TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
