<Window x:Class="TranslationHelper.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen – TranslationHelper"
        Width="480" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Access Key ID:"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="AccessKeyBox" Margin="0,4"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Secret Access Key:"/>
        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="SecretKeyBox" Padding="4,3" Margin="0,4" VerticalContentAlignment="Center"/>

        <Label Grid.Row="2" Grid.Column="0" Content="AWS Region:"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="RegionBox" Margin="0,4"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Model ID:"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="ModelIdBox" Margin="0,4"/>

        <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                   Text="Beispiel-Model: anthropic.claude-sonnet-4-5 | Region: us-east-1"
                   Foreground="Gray" FontSize="11" Margin="0,4,0,0"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Speichern" Width="90" Margin="0,0,8,0" IsDefault="True" Click="SaveButton_Click"/>
            <Button Content="Abbrechen" Width="90" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
