<Window x:Class="SolutionRelocator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SolutionRelocator.ViewModels"
        Title="SVN Solution Relocator"
        Width="1100" Height="650"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Verzeichnis + Suchtiefe -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Verzeichnis:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
            <Button Grid.Column="2" Content="Durchsuchen" Command="{Binding BrowseCommand}" Margin="8,0,0,0" Padding="12,4" />

            <TextBlock Grid.Column="3" Text="Suchtiefe:" VerticalAlignment="Center" Margin="16,0,8,0" />
            <ComboBox Grid.Column="4" ItemsSource="{Binding DepthOptions}" SelectedItem="{Binding MaxDepth}" Width="50" VerticalAlignment="Center" />

            <Button Grid.Column="5" Content="Scannen" Command="{Binding ScanCommand}" Margin="8,0,0,0" Padding="16,4" FontWeight="Bold" />
        </Grid>

        <!-- Row 1: Suchen / Ersetzen / Modus -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Modus:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding SearchModeOptions}" SelectedItem="{Binding SearchMode}" Width="100" VerticalAlignment="Center" />

            <TextBlock Grid.Column="2" Text="Suchen:" VerticalAlignment="Center" Margin="16,0,8,0" />
            <TextBox Grid.Column="3" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />

            <TextBlock Grid.Column="4" Text="Ersetzen:" VerticalAlignment="Center" Margin="16,0,8,0" />
            <TextBox Grid.Column="5" Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
        </Grid>

        <!-- Row 2: Aktionen -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0" Content="Alle auswählen" IsChecked="{Binding AllSelected}" VerticalAlignment="Center" />

            <Button Grid.Column="2" Content="Prüfen" Command="{Binding CheckCommand}" Padding="16,4" Margin="0,0,8,0" />
            <Button Grid.Column="3" Content="Relocate ausführen" Command="{Binding RelocateCommand}" Padding="16,4" FontWeight="Bold" />
        </Grid>

        <!-- Row 3: DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding WorkingCopies}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8F8F8"
                  HeadersVisibility="Column"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">

            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="&#x2611;" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40" />
                <DataGridTextColumn Header="Relativer Pfad" Binding="{Binding RelativePath}" Width="200" IsReadOnly="True" />
                <DataGridTextColumn Header="Aktuelle URL" Binding="{Binding CurrentUrl}" Width="250" IsReadOnly="True" />
                <DataGridTextColumn Header="Neue URL" Binding="{Binding NewUrl}" Width="250" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Blue" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Rev (Alt)" Binding="{Binding CurrentRevision}" Width="80" IsReadOnly="True" />
                <DataGridTextColumn Header="Rev (Neu)" Binding="{Binding NewRevision}" Width="80" IsReadOnly="True" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Erfolgreich">
                                    <Setter Property="Foreground" Value="Green" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Ziel existiert nicht">
                                    <Setter Property="Foreground" Value="Orange" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 4: Statusleiste -->
        <StatusBar Grid.Row="4" Margin="0,8,0,0">
            <StatusBarItem>
                <ProgressBar IsIndeterminate="True" Width="100" Height="14"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
